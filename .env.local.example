# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and is the only env file loaded by Next.js in dev.

# Supabase — project URL is safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service-role key — server-only, never expose to browser
SUPABASE_SECRET_KEY=your-service-role-key

# Anthropic — server-only (used in app/api/generate/route.js)
ANTHROPIC_API_KEY=your-anthropic-api-key

# fal.ai — server-only (used in app/api/generate/route.js)
FAL_KEY=your-fal-api-key

# Telegram bot — server-only (used in app/api/hermes-webhook/route.js)
# TELEGRAM_BOT_TOKEN: from @BotFather when you created the bot
# TELEGRAM_WEBHOOK_SECRET: any random string you generate (e.g. openssl rand -hex 32)
#   Telegram echoes it back in X-Telegram-Bot-Api-Secret-Token on every webhook POST.
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_SECRET=your-random-webhook-secret

# Telegram user account (MTProto / GramJS) — server-only (used in app/api/fetch-group-news/route.js)
# TELEGRAM_API_ID and TELEGRAM_API_HASH: from https://my.telegram.org/apps (create an app).
# TELEGRAM_USER_SESSION: generated by running `node scripts/telegram-login.mjs` once locally.
#   Copy the printed session string here and into Vercel — do NOT commit it.
# TELEGRAM_GROUP_IDENTIFIER: the news group's numeric chat ID (find it with
#   `node scripts/list-telegram-dialogs.mjs`) OR its @username if it has one.
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash
TELEGRAM_USER_SESSION=your-session-string
TELEGRAM_GROUP_IDENTIFIER=your-group-id-or-username
